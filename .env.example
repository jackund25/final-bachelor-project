# ============================================================
# Diabetes Digital Twin — Environment Configuration
# Copy this file to .env and fill in the values.
# ============================================================

# ─── LLM Provider ───────────────────────────────────────────
# Options: gemini | ollama | template
LLM_PROVIDER=gemini

# Google Gemini API key (free tier at https://aistudio.google.com/app/apikey)
GOOGLE_API_KEY=your_google_api_key_here

# Gemini model. gemini-2.5-flash-lite: free-tier besar (~1000 req/hari), cukup untuk advisory.
# Catatan kuota bisa beda antar-project. gemini-1.5-flash sudah 404; 2.5-flash hanya 20/hari;
# 2.0-flash sering 0. Cek model & kuota: panggil tiap model 1x (429 memuat 'limit: N').
# Daftar model: GET https://generativelanguage.googleapis.com/v1beta/models?key=YOUR_KEY
GEMINI_MODEL=gemini-2.5-flash-lite

# ─── Embedding Provider ─────────────────────────────────────
# Options: sentence-transformers | google | ollama
# sentence-transformers: CPU-only, ~80MB download once, no server needed (recommended)
EMBED_PROVIDER=sentence-transformers

# ─── ChromaDB ───────────────────────────────────────────────
CHROMA_PERSIST_DIR=models/chroma_db
CHROMA_COLLECTION_NAME=diabetes_kb
TOP_K_RETRIEVE=10
TOP_K_RERANK=4

# ─── Ollama (optional, for offline/local LLM fallback) ──────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_LLM_MODEL=llama3.1:8b
OLLAMA_EMBED_MODEL=nomic-embed-text

# ─── LangChain tracing (optional) ───────────────────────────
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
